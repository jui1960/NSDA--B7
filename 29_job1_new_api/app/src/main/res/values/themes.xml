<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.JUI_9_REST01" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- স্ট্যাটাস বার পুনরায় দৃশ্যমান করার জন্য নিচের লাইনগুলো নিশ্চিত করুন -->
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>

        <!-- স্ট্যাটাস বারের লেখাগুলো কালো করার জন্য (যদি ব্যাকগ্রাউন্ড সাদা হয়) -->
        <item name="android:windowLightStatusBar">true</item>

        <!-- স্ট্যাটাস বারের কালার সেট করা (ঐচ্ছিক) -->
        <item name="android:statusBarColor">@android:color/white</item>
    </style>

    <style name="Theme.JUI_9_REST01" parent="Base.Theme.JUI_9_REST01" />
</resources>