<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDF7F5">

    <androidx.cardview.widget.CardView
        android:id="@+id/layoutMyProfile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardElevation="0dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_profile_header"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="28dp">

            <TextView
                android:id="@+id/tvMyProfileTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MY PROFILE"
                android:textColor="#80FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvMyProfileName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Your Name"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textAlignment="viewStart"
                app:layout_constraintTop_toBottomOf="@id/tvMyProfileTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvMyProfileEmail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="your@email.com"
                android:textColor="#99FFFFFF"
                android:textSize="13sp"
                app:layout_constraintTop_toBottomOf="@id/tvMyProfileName"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/divider"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:background="#20FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/tvMyProfileEmail"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />


        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvFriendListHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Friend List"
        android:textColor="#0D2320"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="22dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toBottomOf="@id/layoutMyProfile"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/userRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintTop_toBottomOf="@id/tvFriendListHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_user" />

    <LinearLayout
        android:id="@+id/fabContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="vertical"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:contentDescription="Profile"
            android:src="@drawable/ic_person"
            android:visibility="gone"
            app:backgroundTint="#FFFFFF"
            app:fabSize="mini"
            app:tint="#00695C"
            app:elevation="6dp"
            app:rippleColor="#E0F2F1" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabShowMap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:contentDescription="Map"
            android:src="@drawable/map"
            android:visibility="gone"
            app:backgroundTint="#FFFFFF"
            app:fabSize="mini"
            app:tint="#00695C"
            app:elevation="6dp"
            app:rippleColor="#E0F2F1" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:contentDescription="Logout"
            android:src="@drawable/ic_logout"
            android:visibility="gone"
            app:backgroundTint="#FFFFFF"
            app:fabSize="mini"
            app:tint="#D32F2F"
            app:elevation="6dp"
            app:rippleColor="#FFEBEE" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabMain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Menu"
            android:src="@drawable/ic_dashboard"
            app:backgroundTint="#00695C"
            app:tint="@color/white"
            app:elevation="12dp"
            app:rippleColor="#004D40" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>